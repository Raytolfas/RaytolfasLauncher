<Window x:Class="RaytolfasLauncher.ElyByLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ely.by"
        Height="300"
        Width="420"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="NoResize">

    <Border BorderBrush="#1A1A1A" BorderThickness="1" CornerRadius="20" Background="#121212">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="TitleText"
                       Text="ELY.BY"
                       Foreground="#BB86FC"
                       FontSize="20"
                       FontWeight="Bold"
                       Margin="0,0,0,16"/>

            <TextBlock x:Name="LoginLabel" Grid.Row="1" Text="ЛОГИН ИЛИ E-MAIL" Foreground="Gray" FontSize="10" Margin="0,0,0,6"/>
            <TextBox x:Name="LoginBox" Grid.Row="2" Background="#2D2D2D" Foreground="White" BorderThickness="0" Padding="10"/>

            <StackPanel Grid.Row="3" Margin="0,12,0,0">
                <TextBlock x:Name="PasswordLabel" Text="ПАРОЛЬ" Foreground="Gray" FontSize="10" Margin="0,0,0,6"/>
                <PasswordBox x:Name="PasswordBox" Background="#2D2D2D" Foreground="White" BorderThickness="0" Padding="10"/>
                <TextBlock x:Name="TotpLabel" Text="2FA TOKEN (НЕОБЯЗАТЕЛЬНО)" Foreground="Gray" FontSize="10" Margin="0,12,0,6"/>
                <TextBox x:Name="TotpBox" Background="#2D2D2D" Foreground="White" BorderThickness="0" Padding="10"/>
            </StackPanel>

            <TextBlock x:Name="HintText"
                       Grid.Row="4"
                       Text="Если у тебя включена двухфакторная защита, введи код в поле 2FA."
                       Foreground="Gray"
                       TextWrapping="Wrap"
                       Margin="0,14,0,0"/>

            <Grid Grid.Row="5" Margin="0,18,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="CancelButton" Grid.Column="0" Content="ОТМЕНА" Click="Cancel_Click" Height="42" Margin="0,0,6,0" Background="#2D2D2D" Foreground="White" BorderThickness="0">
                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="10"/></Style></Button.Resources>
                </Button>
                <Button x:Name="LoginButton" Grid.Column="1" Content="ВОЙТИ" Click="Login_Click" Height="42" Margin="6,0,0,0" Background="#BB86FC" Foreground="Black" FontWeight="Bold" BorderThickness="0">
                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="10"/></Style></Button.Resources>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>
