<Window x:Class="RaytolfasLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        Title="Raytolfas Launcher" Height="550" Width="900" 
        WindowStartupLocation="CenterScreen" Background="Transparent" 
        AllowsTransparency="True" WindowStyle="None"
        MouseDown="Window_MouseDown">

    <Window.Resources>
        <SolidColorBrush x:Key="MenuBackground" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="MenuText" Color="White"/>
        <SolidColorBrush x:Key="MenuHover" Color="#333333"/>

        <Style x:Key="RaytolfasMenuStyle" TargetType="{x:Type ContextMenu}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ContextMenu}">
                        <Border Background="{StaticResource MenuBackground}"
                                CornerRadius="12"
                                BorderBrush="#3A3A3A"
                                BorderThickness="1"
                                Padding="6">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12" ShadowDepth="4" Opacity="0.35"/>
                            </Border.Effect>
                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RaytolfasItemStyle" TargetType="{x:Type MenuItem}">
            <Setter Property="Foreground" Value="{StaticResource MenuText}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type MenuItem}">
                        <Border x:Name="ItemBorder" Background="Transparent" CornerRadius="8" Margin="2">
                            <ContentPresenter ContentSource="Header" Margin="{TemplateBinding Padding}" HorizontalAlignment="Left"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource MenuHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RaySeparatorStyle" TargetType="{x:Type Separator}">
            <Setter Property="Margin" Value="10,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Separator}">
                        <Border Height="1" Background="#444444" Margin="{TemplateBinding Margin}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RayCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="Box" Width="16" Height="16" CornerRadius="4" Background="#2D2D2D" BorderBrush="#3A3A3A" BorderThickness="1" Margin="0,0,8,0">
                                <Path x:Name="CheckMark" Data="M 3 8 L 6.5 11.5 L 13 4.5" Stroke="#BB86FC" StrokeThickness="2" Visibility="Collapsed" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            </Border>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="#343434"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="Box" Property="BorderBrush" Value="#BB86FC"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RayComboBoxItemStyle" TargetType="{x:Type ComboBoxItem}">
            <Setter Property="Foreground" Value="#BB86FC"/>
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                        <Border x:Name="ItemBorder" Background="{TemplateBinding Background}" CornerRadius="8" Margin="4,2">
                            <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#32263D"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#4B2A69"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RayComboToggleButtonStyle" TargetType="{x:Type ToggleButton}">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border Background="Transparent">
                            <Path x:Name="Arrow"
                                  Data="M 0 0 L 4 4 L 8 0"
                                  Stroke="#BB86FC"
                                  StrokeThickness="1.8"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Arrow" Property="Stroke" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Arrow" Property="Stroke" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RayComboBoxStyle" TargetType="{x:Type ComboBox}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="BorderBrush" Value="#403A35"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="MaxDropDownHeight" Value="220"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource RayComboBoxItemStyle}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <Border x:Name="RootBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="34"/>
                                    </Grid.ColumnDefinitions>

                                    <ContentPresenter Margin="{TemplateBinding Padding}"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      RecognizesAccessKey="True"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                                      TextElement.Foreground="{TemplateBinding Foreground}"/>

                                    <ToggleButton Grid.Column="1"
                                                  Style="{StaticResource RayComboToggleButtonStyle}"
                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                  ClickMode="Press"/>
                                </Grid>
                            </Border>

                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade"
                                   IsOpen="{TemplateBinding IsDropDownOpen}">
                                <Border MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Margin="0,6,0,0"
                                        Padding="4"
                                        Background="#1A1A1A"
                                        BorderBrush="#403A35"
                                        BorderThickness="1"
                                        CornerRadius="12">
                                    <ScrollViewer MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                                  SnapsToDevicePixels="True"
                                                  CanContentScroll="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="#6A4D86"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="#BB86FC"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="#BB86FC"/>
                            </Trigger>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="PART_Popup" Property="MinHeight" Value="40"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="24" Background="#121212" BorderBrush="Transparent" BorderThickness="0">
        <Border.OpacityMask>
            <VisualBrush>
                <VisualBrush.Visual>
                    <Border Background="Black" 
                            CornerRadius="24" 
                            Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Border}}"
                            Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Border}}"/>
                </VisualBrush.Visual>
            </VisualBrush>
        </Border.OpacityMask>

        <Grid>
            <tb:TaskbarIcon x:Name="MyNotifyIcon"
                            IconSource="Assets/logo.ico"
                            ToolTipText="Raytolfas Launcher"
                            TrayLeftMouseUp="TrayIcon_TrayLeftMouseUp">
                <tb:TaskbarIcon.ContextMenu>
                    <ContextMenu Style="{StaticResource RaytolfasMenuStyle}">
                        <MenuItem x:Name="TrayOpenMenuItem" Header="ОТКРЫТЬ ЛАУНЧЕР" Click="ToggleWindow_Click" Style="{StaticResource RaytolfasItemStyle}"/>
                        <Separator Style="{StaticResource RaySeparatorStyle}"/>
                        <MenuItem x:Name="TrayExitMenuItem" Header="ВЫХОД" Click="ShutdownApp_Click" Style="{StaticResource RaytolfasItemStyle}"/>
                    </ContextMenu>
                </tb:TaskbarIcon.ContextMenu>
            </tb:TaskbarIcon>

            <Image x:Name="MainBgImage" Stretch="UniformToFill" Source="Assets/background.png" Opacity="0.4">
                <Image.Effect>
                    <BlurEffect Radius="15"/>
                </Image.Effect>
            </Image>

            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="25">
                    <Button Content="❤️" Click="OpenDonateWeb_Click" Background="Transparent" Foreground="White" BorderThickness="0" FontSize="22" Cursor="Hand" Margin="0,0,15,0"/>
                    <Button Content="☁️" Click="LoadServers_Click" Background="Transparent" Foreground="White" BorderThickness="0" FontSize="22" Cursor="Hand" Margin="0,0,15,0"/>
                    <Button Content="📝" Click="CheckUpdateBtn_Click" Background="Transparent" Foreground="White" BorderThickness="0" FontSize="22" Cursor="Hand" Margin="0,0,15,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="25">
                    <Button Content="📂" Background="Transparent" Foreground="White" BorderThickness="0" FontSize="22" Cursor="Hand" Margin="0,0,15,0">
                        <Button.ContextMenu>
                            <ContextMenu Style="{StaticResource RaytolfasMenuStyle}">
                                <MenuItem x:Name="RootFolderMenuItem" Header="Коренная папка" Click="OpenRootFolder_Click" Style="{StaticResource RaytolfasItemStyle}"/>
                                <MenuItem x:Name="ModsFolderMenuItem" Header="Моды (mods)" Click="OpenModsFolder_Click" Style="{StaticResource RaytolfasItemStyle}"/>
                                <MenuItem x:Name="SavesFolderMenuItem" Header="Миры (saves)" Click="OpenSavesFolder_Click" Style="{StaticResource RaytolfasItemStyle}"/>
                                <Separator Style="{StaticResource RaySeparatorStyle}"/>
                                <MenuItem x:Name="ScreenshotsFolderMenuItem" Header="Скриншоты" Click="OpenScreenshotsFolder_Click" Style="{StaticResource RaytolfasItemStyle}"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                        <Button.Style>
                            <Style TargetType="Button">
                                <EventSetter Event="Click" Handler="OpenFolderMenu_Click"/>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="⚙️" Click="SettingsBtn_Click" Background="Transparent" Foreground="White" BorderThickness="0" FontSize="22" Cursor="Hand" Margin="0,0,15,0"/>
                    <Button Content="✕" Click="CloseBtn_Click" Background="Transparent" Foreground="White" BorderThickness="0" FontSize="22" Cursor="Hand"/>
                </StackPanel>

                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Image Source="Assets/title.png" MaxWidth="350" Stretch="Uniform" Margin="5,0,5,25" />

                    <Border Background="#CC1E1E1E" CornerRadius="20" Padding="35" Width="420">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <Border x:Name="PlayerAvatarContainer" Width="32" Height="32" CornerRadius="4" Background="#2D2D2D" Margin="0,0,10,0">
                                    <Image x:Name="PlayerAvatar" Source="https://minotar.net/avatar/char/32" Stretch="UniformToFill"/>
                                </Border>
                                <Label x:Name="AccountSectionLabel" Content="АККАУНТ" Foreground="#BB86FC" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="AccountSelector" Height="36" Style="{StaticResource RayComboBoxStyle}" 
                                        VerticalContentAlignment="Center" SelectionChanged="AccountSelector_SelectionChanged">
                                    <ComboBox.Resources>
                                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="10"/></Style>
                                    </ComboBox.Resources>
                                </ComboBox>
                                <Button Grid.Column="1" Content="✏️" Width="36" Height="36" Margin="10,0,0,0" Click="OpenAccountManager_Click" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="#2D2D2D" CornerRadius="10">
                                                <TextBlock Text="✏️" Foreground="White" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,3"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>

                            <Label x:Name="VersionSectionLabel" Content="ВЕРСИЯ" Foreground="#BB86FC" FontSize="11" FontWeight="Bold" Margin="0,0,0,2"/>
                            <Grid Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="VersionBox" Height="36" Style="{StaticResource RayComboBoxStyle}" VerticalContentAlignment="Center" SelectionChanged="VersionBox_SelectionChanged">
                                    <ComboBox.Resources>
                                        <Style TargetType="{x:Type Border}"><Setter Property="CornerRadius" Value="10"/></Style>
                                    </ComboBox.Resources>
                                </ComboBox>
                                <Button Grid.Column="1" Content="🔄" Width="36" Height="36" Margin="10,0,0,0" Click="Refresh_Click" Cursor="Hand" Foreground="White" FontSize="20">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="#2D2D2D" CornerRadius="10">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>

                            <CheckBox x:Name="CheckBoxForce" Content="Переустановить файлы" Style="{StaticResource RayCheckBoxStyle}" Margin="0,0,0,30"/>

                            <Button x:Name="LaunchBtn" Content="ИГРАТЬ" Height="65" Click="LaunchBtn_Click" Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="FontSize" Value="22"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Grid x:Name="grid">
                                                        <Border Background="#22000000" Margin="2,2,-2,-2" />
                                                        <Grid>
                                                            <Rectangle x:Name="mainRect">
                                                                <Rectangle.Fill>
                                                                    <DrawingBrush TileMode="Tile" Viewport="0,0,33,33" ViewportUnits="Absolute">
                                                                        <DrawingBrush.Drawing>
                                                                            <DrawingGroup>
                                                                                <GeometryDrawing Brush="#3a8f32"><GeometryDrawing.Geometry><RectangleGeometry Rect="0,0,12,12" /></GeometryDrawing.Geometry></GeometryDrawing>
                                                                                <GeometryDrawing Brush="#26701f"><GeometryDrawing.Geometry><RectangleGeometry Rect="12,0,12,12" /></GeometryDrawing.Geometry></GeometryDrawing>
                                                                                <GeometryDrawing Brush="#1e5c17"><GeometryDrawing.Geometry><RectangleGeometry Rect="0,12,12,12" /></GeometryDrawing.Geometry></GeometryDrawing>
                                                                                <GeometryDrawing Brush="#2f7a25"><GeometryDrawing.Geometry><RectangleGeometry Rect="12,12,12,12" /></GeometryDrawing.Geometry></GeometryDrawing>
                                                                            </DrawingGroup>
                                                                        </DrawingBrush.Drawing>
                                                                    </DrawingBrush>
                                                                </Rectangle.Fill>
                                                            </Rectangle>
                                                            <Border BorderBrush="#33000000" BorderThickness="0,0,0,3" VerticalAlignment="Bottom" Height="5"/>
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        </Grid>
                                                        <Rectangle x:Name="hoverOverlay" Fill="White" Opacity="0"/>
                                                    </Grid>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="hoverOverlay" Property="Opacity" Value="0.1"/>
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="grid" Property="RenderTransform">
                                                                <Setter.Value><TranslateTransform Y="2"/></Setter.Value>
                                                            </Setter>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <StackPanel x:Name="DownloadPanel" Visibility="Collapsed" Margin="0,10,0,0">
                                <TextBlock x:Name="StatusLabel" Text="Подготовка..." Foreground="White" FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                <ProgressBar x:Name="DownloadProgress" Height="15" Foreground="#BB86FC" Background="#2D2D2D"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <Border x:Name="SettingsModal" Background="#F8121212" CornerRadius="19" Visibility="Collapsed">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="400">
                    <TextBlock x:Name="SettingsTitleText" Text="НАСТРОЙКИ" Foreground="White" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="350">
                        <StackPanel Margin="10,0,20,0">
                            <Label x:Name="BackgroundLabel" Content="ФОН ЛАУНЧЕРА:" Foreground="Gray" FontSize="10"/>
                            <Grid Margin="0,5,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="BgPathBox" IsReadOnly="True" Background="#2D2D2D" Foreground="White" BorderThickness="0" Padding="8" VerticalContentAlignment="Center"/>
                                <Button x:Name="SelectBackgroundButton" Grid.Column="1" Content="ВЫБРАТЬ" Click="SelectBackground_Click" Width="80" Margin="10,0,0,0" Background="#BB86FC" Foreground="Black" FontWeight="Bold">
                                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="5"/></Style></Button.Resources>
                                </Button>
                            </Grid>

                            <Label x:Name="GameFolderLabel" Content="ПАПКА ИГРЫ:" Foreground="Gray" FontSize="10"/>
                            <Grid Margin="0,5,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="PathBox" IsReadOnly="True" Background="#2D2D2D" Foreground="White" BorderThickness="0" Padding="8" VerticalContentAlignment="Center"/>
                                <Button x:Name="BrowsePathButton" Grid.Column="1" Content="ОБЗОР" Click="SelectPath_Click" Width="80" Margin="10,0,0,0" Background="#BB86FC" Foreground="Black" FontWeight="Bold">
                                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="5"/></Style></Button.Resources>
                                </Button>
                            </Grid>

                            <Label x:Name="OptionsLabel" Content="ОПЦИИ:" Foreground="Gray" FontSize="10"/>
                            <StackPanel Margin="0,5,0,15">
                                <CheckBox x:Name="CbDiscordRPC" Content="Discord Rich Presence" Style="{StaticResource RayCheckBoxStyle}" IsChecked="True" Margin="0,5"/>
                                <CheckBox x:Name="CbHideLauncher" Content="Скрывать лаунчер при запуске" Style="{StaticResource RayCheckBoxStyle}" Margin="0,5"/>
                                <CheckBox x:Name="CbShowAvatar" Content="Показывать аватарку аккаунта" Style="{StaticResource RayCheckBoxStyle}" IsChecked="True" Margin="0,5"/>
                                <CheckBox x:Name="CbOpenLogWindow" Content="Открывать окно логов при запуске" Style="{StaticResource RayCheckBoxStyle}" IsChecked="False" Margin="0,5" Checked="CbOpenLogWindow_Checked"/>
                                <CheckBox x:Name="CbElyBySkins" Content="Включить скины Ely.by" Style="{StaticResource RayCheckBoxStyle}" Margin="0,5"/>
                            </StackPanel>

                            <Label x:Name="LanguageLabel" Content="ЯЗЫК:" Foreground="Gray" FontSize="10" Margin="0,0,0,0"/>
                            <Grid Margin="0,5,0,10">
                                <ComboBox x:Name="LanguageBox" Height="36" Style="{StaticResource RayComboBoxStyle}" VerticalContentAlignment="Center" SelectionChanged="LanguageBox_SelectionChanged">
                                    <ComboBox.Resources>
                                        <Style TargetType="{x:Type Border}"><Setter Property="CornerRadius" Value="10"/></Style>
                                    </ComboBox.Resources>
                                </ComboBox>
                            </Grid>

                            <Label x:Name="JavaProfileLabel" Content="ПРОФИЛЬ JAVA:" Foreground="Gray" FontSize="10" Margin="0,10,0,0"/>
                            <Grid Margin="0,5,0,10">
                                <ComboBox x:Name="JavaProfileBox" Height="36" Style="{StaticResource RayComboBoxStyle}" 
                                        VerticalContentAlignment="Center" SelectionChanged="JavaProfileBox_SelectionChanged">
                                    <ComboBox.Resources>
                                        <Style TargetType="{x:Type Border}"><Setter Property="CornerRadius" Value="10"/></Style>
                                    </ComboBox.Resources>
                                </ComboBox>
                            </Grid>

                            <Label x:Name="JavaPathLabel" Content="ПУТЬ К JAVA (Оставьте пустым для AUTO):" Foreground="Gray" FontSize="10" Margin="0,10,0,0"/>
                            <TextBox x:Name="JavaPathBox" Background="#2D2D2D" Foreground="White" BorderThickness="0" Padding="8"/>

                            <Label x:Name="ResolutionLabel" Content="РАЗРЕШЕНИЕ И ЭКРАН:" Foreground="Gray" FontSize="10" Margin="0,10,0,0"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="WinWidthBox" Width="60" Text="854" Background="#2D2D2D" Foreground="White" BorderThickness="0" Padding="5"/>
                                <TextBlock Text="x" Foreground="Gray" VerticalAlignment="Center" Margin="5,0"/>
                                <TextBox x:Name="WinHeightBox" Width="60" Text="480" Background="#2D2D2D" Foreground="White" BorderThickness="0" Padding="5"/>
                                <CheckBox x:Name="CbFullScreen" Content="Полный экран" Style="{StaticResource RayCheckBoxStyle}" Margin="15,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>

                            <Label x:Name="JavaArgsLabel" Content="АРГУМЕНТЫ JAVA:" Foreground="Gray" FontSize="10" Margin="0,10,0,0"/>
                            <TextBox x:Name="JavaArgsBox" Background="#2D2D2D" Foreground="White" BorderThickness="0" Padding="8" Text="-XX:+UseG1GC"/>

                            <Label x:Name="VersionFiltersLabel" Content="ОТОБРАЖАТЬ ВЕРСИИ:" Foreground="Gray" FontSize="10"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,15">
                                <CheckBox x:Name="CbReleases" Content="Релизы" Style="{StaticResource RayCheckBoxStyle}" IsChecked="True" Margin="5"/>
                                <CheckBox x:Name="CbSnapshots" Content="Снапшоты" Style="{StaticResource RayCheckBoxStyle}" Margin="5"/>
                                <CheckBox x:Name="CbModded" Content="Моды" Style="{StaticResource RayCheckBoxStyle}" IsChecked="True" Margin="5"/>
                            </StackPanel>

                            <StackPanel>
                                <Label x:Name="RamLabel" Content="ОПЕРАТИВНАЯ ПАМЯТЬ:" Foreground="Gray" FontSize="10"/>
                                
                                <Slider x:Name="RamSlider" 
                                        Minimum="1024" 
                                        Maximum="16384" 
                                        Value="4096" 
                                        TickFrequency="1024" 
                                        TickPlacement="None" 
                                        IsSnapToTickEnabled="True"/>

                                <UniformGrid Columns="5" Margin="0,-5,0,10">
                                    <TextBlock Text="1GB" Foreground="Gray" FontSize="9" HorizontalAlignment="Left"/>
                                    <TextBlock Text="4GB" Foreground="Gray" FontSize="9" HorizontalAlignment="Center"/>
                                    <TextBlock Text="8GB" Foreground="Gray" FontSize="9" HorizontalAlignment="Center"/>
                                    <TextBlock Text="12GB" Foreground="Gray" FontSize="9" HorizontalAlignment="Center"/>
                                    <TextBlock Text="16GB" Foreground="Gray" FontSize="9" HorizontalAlignment="Right"/>
                                </UniformGrid>

                                <TextBlock Text="{Binding ElementName=RamSlider, Path=Value, StringFormat={}{0} MB}" 
                                        Foreground="#BB86FC" 
                                        FontWeight="Bold"
                                        HorizontalAlignment="Center" 
                                        Margin="0,0,0,20"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <Button x:Name="SaveSettingsButton" Content="СОХРАНИТЬ" Click="SaveSettings_Click" Height="40" Background="#BB86FC" FontWeight="Bold">
                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style></Button.Resources>
                    </Button>
                </StackPanel>
            </Border>

            <Grid x:Name="ServerModal" Visibility="Collapsed" Background="#AA000000">
                <Border Background="#171717" CornerRadius="20" Width="620" Height="400" VerticalAlignment="Center" HorizontalAlignment="Center" BorderBrush="#1A1A1A" BorderThickness="1">
                    <Grid Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock x:Name="ModCenterTitleText" Text="МОД-ЦЕНТР" Foreground="White" FontSize="22" FontWeight="Bold"/>
                                <TextBlock x:Name="ModCenterSubtitleText" Text="Установка Fabric, Forge и Modrinth pack прямо из лаунчера" Foreground="Gray" FontSize="12" Margin="0,4,0,0"/>
                            </StackPanel>

                            <Button Grid.Column="1" Content="✕" Click="CloseServerModal_Click" Background="Transparent" Foreground="Gray" BorderThickness="0" Width="36" Height="36" FontSize="20"/>
                        </Grid>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,14,0,14">
                            <Button x:Name="LoadersTabButton" Content="FABRIC / FORGE" Click="ShowLoadersTab_Click" Height="34" Width="150" Margin="0,0,10,0" Background="#BB86FC" Foreground="Black" FontWeight="Bold" BorderThickness="0">
                                <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="10"/></Style></Button.Resources>
                            </Button>
                            <Button x:Name="ModrinthTabButton" Content="СБОРКА .MRPACK" Click="ShowModrinthTab_Click" Height="34" Width="150" Background="#2D2D2D" Foreground="White" FontWeight="Bold" BorderThickness="0">
                                <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="10"/></Style></Button.Resources>
                            </Button>
                        </StackPanel>

                        <Grid x:Name="LoadersTabPanel" Grid.Row="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <UniformGrid Columns="3" Margin="0,0,0,12">
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock x:Name="LoaderTypeLabel" Text="LOADER" Foreground="Gray" FontSize="10" Margin="0,0,0,6"/>
                                    <ComboBox x:Name="LoaderTypeBox" Height="32" Style="{StaticResource RayComboBoxStyle}" SelectionChanged="LoaderTypeBox_SelectionChanged"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock x:Name="LoaderGameVersionLabel" Text="MINECRAFT" Foreground="Gray" FontSize="10" Margin="0,0,0,6"/>
                                    <ComboBox x:Name="LoaderGameVersionBox" Height="32" Style="{StaticResource RayComboBoxStyle}" SelectionChanged="LoaderGameVersionBox_SelectionChanged"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock x:Name="LoaderVersionLabel" Text="СБОРКА LOADER" Foreground="Gray" FontSize="10" Margin="0,0,0,6"/>
                                    <ComboBox x:Name="LoaderVersionBox" Height="32" Style="{StaticResource RayComboBoxStyle}"/>
                                </StackPanel>
                            </UniformGrid>

                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
                                <Button x:Name="RefreshLoaderButton" Content="ОБНОВИТЬ СПИСОК" Click="RefreshLoaderVersions_Click" Height="34" Width="150" Margin="0,0,8,0" Background="#2D2D2D" Foreground="White" BorderThickness="0">
                                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="10"/></Style></Button.Resources>
                                </Button>
                                <Button x:Name="InstallLoaderButton" Content="УСТАНОВИТЬ ВЕРСИЮ" Click="InstallSelectedLoader_Click" Height="34" Width="170" Background="#BB86FC" Foreground="Black" FontWeight="Bold" BorderThickness="0">
                                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="10"/></Style></Button.Resources>
                                </Button>
                            </StackPanel>

                            <Border Grid.Row="2" Background="#111111" CornerRadius="14" Padding="14">
                                <StackPanel>
                                    <TextBlock x:Name="LoadersInfoTitleText" Text="Что умеет этот раздел" Foreground="White" FontWeight="Bold" FontSize="15"/>
                                    <TextBlock x:Name="LoadersInfoLine1Text" Text="Ставит выбранную версию Fabric или Forge в текущую папку игры." Foreground="Gray" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                    <TextBlock x:Name="LoadersInfoLine2Text" Text="После установки версия сразу появится в основном списке версий." Foreground="Gray" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid x:Name="ModrinthTabPanel" Grid.Row="2" Visibility="Collapsed">
                            <Border Background="#111111" CornerRadius="16" Padding="18" Margin="0,4,0,0">
                                <StackPanel>
                                    <TextBlock x:Name="MrPackTitleText" Text="СКОРО..." Foreground="White" FontWeight="Bold" FontSize="18"/>
                                    <TextBlock x:Name="MrPackSubtitleText" Text="Раздел установки .mrpack появится позже." Foreground="Gray" Margin="0,10,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <StackPanel Grid.Row="3" Margin="0,16,0,0">
                            <ProgressBar x:Name="ModCenterProgress" Height="8" Visibility="Collapsed" IsIndeterminate="True" Foreground="#BB86FC" Background="#2D2D2D"/>
                            <TextBlock x:Name="ModCenterStatusText" Foreground="Gray" Margin="0,10,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
            <Grid VerticalAlignment="Bottom" Margin="10,0,10,10">
                <TextBlock x:Name="VersionText" Text="v...(грузитсьсяяя)" 
                        Foreground="Gray" FontSize="12" 
                        HorizontalAlignment="Left" VerticalAlignment="Bottom"/>

                <TextBlock Text="powered by raytolfas"
                        Foreground="Gray" FontSize="12" 
                        HorizontalAlignment="Right" VerticalAlignment="Bottom"
                        >
                </TextBlock>
            </Grid>
        </Grid>
    </Border>
</Window>
